#!/usr/bin/env python3
# Plot a sky (observer's-perspective) chart for Project Hail Mary.
#
# Shows where the story's key star systems appear in Earth's night sky,
# with directed orange arcs tracing the Astrophage transmission path.
# Constellation stick figures are included as orientation aids for readers
# who are not familiar with the night sky.
#
# Copyright 2026 David A. Wheeler and plot-stars contributors
# SPDX-License-Identifier: GPL-2.0-or-later
#
# The resulting chart is licensed Creative Commons Attribution (CC-BY) 3.0+.
# Background star data: starplot Big Sky Catalog (Hipparcos/Tycho, MIT license).

import re
import sys
import pandas as pd

from starplot import MapPlot, Miller, CollisionHandler, _
from starplot.models import Star
from starplot.styles import PlotStyle, extensions, AnchorPointEnum

from star_data import WISE_NAME, SKY_CHART_HIP, SKY_CHART_TRANSMISSIONS

# ---------------------------------------------------------------------------
# Mode selection via command-line flag.
#
# Default (no flag): extended chart — includes Wolf 359, Lalande 21185, and
#   Ross 128 (the remaining WISE targets).  Output: hail-mary-sky.svg
#   RA 18–190°, Dec −37° to +44° — covers Leo/Virgo/Ursa Major.
#
# --limited: compact chart — only the five core story stars visible from the
#   Orion/Canis-Major region.  Output: hail-mary-sky-limited.svg
#   RA 18–142°, Dec −37° to +26°.
# ---------------------------------------------------------------------------
LIMITED = '--limited' in sys.argv
INCLUDE_OUTER_WISE_TARGETS = not LIMITED
OUTPUT_FILE = 'hail-mary-sky-limited.svg' if LIMITED else 'hail-mary-sky.svg'


# ---------------------------------------------------------------------------
# Helper functions: parse RA/Dec strings from nearby.csv.
#
# These are only needed for WISE 0855-0714, whose position is read from
# nearby.csv because it has no Hipparcos entry (see Step 1 below).  The
# logic mirrors the fix_ascension / fix_declination functions in plot-stars
# but is simplified to handle only the formats that appear in the CSV for
# the WISE row.
# ---------------------------------------------------------------------------

def hms_to_deg(s):
    """Convert 'HHh MMm SS.SSs' right-ascension string to decimal degrees."""
    m = re.match(r'(\d+)h\s*(\d+)m\s*([\d.]+)s', s.strip())
    if not m:
        raise ValueError(f'Cannot parse RA: {s!r}')
    h, mn, sec = float(m.group(1)), float(m.group(2)), float(m.group(3))
    return (h + mn / 60.0 + sec / 3600.0) * 15.0   # convert hours → degrees

def dms_to_deg(s):
    """Convert '±DD° MM′ SS.S″' declination string to decimal degrees."""
    s = s.strip()
    sign = -1 if s[0] in '-\u2212' else 1   # accept ASCII '-' or Unicode '−'
    s = s.lstrip('+-\u2212')
    m = re.match(r"(\d+)[°d]\s*(\d+)[′']\s*([\d.]+)", s)
    if not m:
        raise ValueError(f'Cannot parse Dec: {s!r}')
    d, mn, sec = float(m.group(1)), float(m.group(2)), float(m.group(3))
    return sign * (d + mn / 60.0 + sec / 3600.0)

def get_coords_from_csv(name_fragment, csv_path='nearby.csv'):
    """Return (ra_deg, dec_deg) for the first row whose System column contains
    name_fragment.  Used for stars absent from the Hipparcos/starplot catalog."""
    df = pd.read_csv(csv_path)
    row = df[df['System'].str.contains(name_fragment, na=False)].iloc[0]
    return hms_to_deg(row['Right ascension']), dms_to_deg(row['Declination'])

def get_wise_coords(csv_path='nearby.csv'):
    """Return (ra_deg, dec_deg) for WISE 0855-0714 read from nearby.csv.

    nearby.csv is the single authoritative coordinate source for WISE because
    the star was discovered in 2014, long after the Hipparcos mission ended,
    so it has no Hipparcos entry and is absent from the starplot catalog.
    """
    return get_coords_from_csv('WISE 0855', csv_path)


# ---------------------------------------------------------------------------
# Step 1 – Gather star positions.
#
# For the four catalog stars we query the starplot Big Sky catalog by
# Hipparcos ID (stored in SKY_CHART_HIP in star_data.py).  Using the
# catalog positions—rather than parsing nearby.csv—guarantees that every
# arrow endpoint sits exactly on the dot that starplot draws, avoiding
# silent coordinate drift between the two data sources.
#
# WISE 0855-0714 is the exception: see get_wise_coords() above.
# ---------------------------------------------------------------------------

print('Looking up catalog positions...')
star_coords = {}   # display name → (ra_deg, dec_deg)

for display_name, hip in SKY_CHART_HIP.items():
    results = list(Star.find(where=[_.hip == hip]))
    if not results:
        raise RuntimeError(
            f'HIP {hip} ({display_name}) not found in starplot catalog'
        )
    s = results[0]
    star_coords[display_name] = (s.ra, s.dec)
    print(f'  {display_name}: RA={s.ra:.4f}°  Dec={s.dec:.4f}°')

wise_ra, wise_dec = get_wise_coords()
star_coords[WISE_NAME] = (wise_ra, wise_dec)
print(f'  WISE 0855-0714 (from nearby.csv): RA={wise_ra:.4f}°  Dec={wise_dec:.4f}°')

# Extended targets — only looked up when INCLUDE_OUTER_WISE_TARGETS is set.
#
# Lalande 21185 is in the Hipparcos catalog (HIP 54035, mag ~7.5).
# Wolf 359 (mag ~13.5) and Ross 128 (mag ~11.1) are too faint for Hipparcos
# and are read from nearby.csv like WISE.
#
# The three names are kept as plain ASCII strings (no Unicode minus) because
# that matches the short system names derived from nearby.csv by plot-stars.
if INCLUDE_OUTER_WISE_TARGETS:
    lalande_hip = 54035
    results = list(Star.find(where=[_.hip == lalande_hip]))
    if not results:
        raise RuntimeError(f'HIP {lalande_hip} (Lalande 21185) not found in starplot catalog')
    s = results[0]
    star_coords['Lalande 21185'] = (s.ra, s.dec)
    print(f'  Lalande 21185: RA={s.ra:.4f}°  Dec={s.dec:.4f}°')

    wolf_ra, wolf_dec = get_coords_from_csv('Wolf 359')
    star_coords['Wolf 359'] = (wolf_ra, wolf_dec)
    print(f'  Wolf 359 (from nearby.csv): RA={wolf_ra:.4f}°  Dec={wolf_dec:.4f}°')

    ross_ra, ross_dec = get_coords_from_csv('Ross 128')
    star_coords['Ross 128'] = (ross_ra, ross_dec)
    print(f'  Ross 128 (from nearby.csv): RA={ross_ra:.4f}°  Dec={ross_dec:.4f}°')


# ---------------------------------------------------------------------------
# Step 2 – Build the sky chart.
#
# Projection
# ----------
# Miller cylindrical.  Well-suited for the low-declination band spanned by
# our stars (Dec ≈ −17° to −7°); the same projection is used in the
# starplot "Map of Canis Major" documentation example.
#
# Bounds
# ------
# RA  18° – 142°  (≈ 1 h 12 m – 9 h 28 m): about 8° of padding either side
#     of the outermost stars (Tau Ceti at 26°, WISE at 134°).
# Dec −37° – +26°: chosen to include the full IAU extents of Orion
#     (Dec −11° to +23°) and Canis Major (Dec −33° to −11°), with ~3–4°
#     of padding.  The previous tighter bounds (−21° to −3°) clipped both
#     constellations, removing the visual context that makes the chart
#     useful for beginners.
#
# RA AXIS DIRECTION
# -----------------
# Sky charts conventionally show RA increasing right-to-left (east is left
# when you look up at the sky).  Starplot follows this convention
# automatically: Tau Ceti (RA ≈ 26°) appears on the RIGHT edge of this
# chart and WISE 0855-0714 (RA ≈ 134°) appears on the LEFT.
# To flip to map-style orientation (RA increases left-to-right), add:
#     p.ax.invert_xaxis()
# after the MapPlot block below.  Flipping may displace some of the
# auto-placed constellation labels.
# ---------------------------------------------------------------------------

print('Building chart...')
style = PlotStyle().extend(
    extensions.BLUE_NIGHT,   # dark blue background, white stars, green constellations
    extensions.MAP,           # adjust label/line sizes for a printed map
)

# Bounds: normal view covers Orion + Canis Major around the five core story
# stars.  Extended view adds Leo/Virgo/Ursa Major to accommodate Wolf 359,
# Lalande 21185, and Ross 128 — roughly doubling the RA span.
if INCLUDE_OUTER_WISE_TARGETS:
    ra_min, ra_max   = 18, 190
    dec_min, dec_max = -37, +44   # +44 gives a few degrees of padding above Lalande (+36°)
else:
    ra_min, ra_max   = 18, 142
    dec_min, dec_max = -37, +26

p = MapPlot(
    projection=Miller(),
    ra_min=ra_min,
    ra_max=ra_max,
    dec_min=dec_min,
    dec_max=dec_max,
    style=style,
    resolution=4096,
)

# Constellation stick figures — the primary orientation aid for beginners.
# Plotted first so stars and arrows render on top of them.
p.constellations()
p.constellation_labels()

# Stars to the naked-eye limit (magnitude < 6.5).
#
# where_labels selects which stars get an automatic catalog-name label.
# We show conventional names for the brightest, best-known stars
# (magnitude < 2.5) to help readers orient themselves — Betelgeuse,
# Rigel, Procyon, Aldebaran, etc.
#
# Exclusions from auto-labels (handled as forced labels below):
#   _.hip != 32349  — Sirius: already added as a custom gold key-star label.
#   _.hip != 27989  — Betelgeuse: collision detection sometimes drops it even
#       though it is one of the most recognisable stars on the chart; we re-add
#       it below with plot_on_fail=True so it always appears.
# Note: a few binary stars (Alnitak, Mintaka) have two catalog entries and
# will produce stacked duplicate labels at the same position; this is
# harmless and invisible since the text is identical.
p.stars(
    where=[_.magnitude < 6.5],
    where_labels=[
        (_.magnitude < 2.5) & (_.hip != 32349) & (_.hip != 27989)
    ],
)

# Forced label for Betelgeuse — matches the auto-label style (22 pt, bold,
# blue-white #ebf0f4) but adds a thin dark halo so it stays readable when
# it overlaps a green constellation line.
_btel = list(Star.find(where=[_.hip == 27989]))[0]
p.text(
    'Betelgeuse',
    ra=_btel.ra,
    dec=_btel.dec,
    style={
        'font_size': 22,
        'font_color': '#ebf0f4',
        'font_weight': 700,
        'offset_x': 8,
        'offset_y': 8,
        'border_width': 1.5,
        'border_color': '#0d1a2a',
    },
    collision_handler=CollisionHandler(plot_on_fail=True),
)

# RA/Dec grid for coordinate reference.
p.gridlines()


# ---------------------------------------------------------------------------
# Step 3 – Custom marker for WISE 0855-0714.
#
# WISE is a sub-brown dwarf, not a true hydrogen-fusing star.  We render it
# as a dim open circle (fill omitted → defaults to FillStyleEnum.NONE) so
# it looks different from the filled star dots plotted by p.stars() above.
# ---------------------------------------------------------------------------
dim_marker_style = {
    'marker': {
        'symbol': 'circle',
        'size': 20,
        'color': '#aaaaaa',     # fill color (visible in FULL fill mode)
        'edge_color': '#cccccc',
        'alpha': 0.9,
    }
}
# WISE, Wolf 359, and Ross 128 are all sub-catalog objects (too faint for
# Hipparcos) — render them as dim open circles.  Lalande 21185 (HIP 54035,
# mag ~7.5) is plotted automatically by p.stars() above.
p.marker(ra=wise_ra, dec=wise_dec, style=dim_marker_style)

if INCLUDE_OUTER_WISE_TARGETS:
    p.marker(ra=wolf_ra,  dec=wolf_dec,  style=dim_marker_style)
    p.marker(ra=ross_ra,  dec=ross_dec,  style=dim_marker_style)


# ---------------------------------------------------------------------------
# Step 4 – Custom labels for the five key story stars.
#
# We label each star with its familiar story name rather than the catalog
# value.  offset_x / offset_y (in points) nudge the text slightly away
# from the star dot so they don't overlap.
#
# border_width / border_color add a dark halo around each label.  Without
# the halo the white text can be unreadable wherever it crosses an orange
# arrow shaft, a green constellation line, or another bright star — Sirius
# in particular sits at the junction of two arcs.
#
# CollisionHandler(plot_on_fail=True): the default handler silently drops a
# label if it cannot find a collision-free position.  Epsilon Eridani is the
# junction of three Astrophage arcs, so every candidate position collides and
# without this flag its label disappears entirely.  plot_on_fail=True forces
# all five key-star labels onto the chart regardless of collisions.
# ---------------------------------------------------------------------------
label_style = {
    # font_size=28 is intentionally slightly larger than the conventional-name
    # auto-labels (which the MAP style extension sets to 22pt) so that readers
    # notice the story-relevant stars even before reading the names.
    'font_size': 28,
    # A warm light gold rather than plain white: visually echoes the orange
    # Astrophage arcs and signals "these stars are special" without being
    # garish.  Plain white (#ffffff) would blend in with the auto-labels.
    'font_color': '#ffd060',
    'font_weight': 700,       # bold; corresponds to FontWeightEnum.BOLD
    'offset_x': 14,
    'offset_y': 14,
    'border_width': 2,        # dark halo keeps text legible over any background
    'border_color': '#0d1a2a',  # near-black dark blue, matching the chart background
}
key_star_collision = CollisionHandler(plot_on_fail=True)

# Per-star placement for Epsilon Eridani.
#
# Epsilon Eridani is the junction of three arrows, so every default anchor
# position collides and CollisionHandler(plot_on_fail=True) falls back to the
# LAST entry in anchor_fallbacks — which is LEFT_CENTER by default.
#
# To force the label above-right of the dot (bottom-left of text box at the
# star), we give Epsilon Eridani its own CollisionHandler whose anchor_fallbacks
# list contains only TOP_RIGHT.  With plot_on_fail=True the handler will always
# land there regardless of collisions.
#
# Why TOP_RIGHT places text UP and to the RIGHT:
#   AnchorPointEnum.as_matplot() inverts names because the sky-chart RA axis is
#   internally negated.  TOP_RIGHT → va='bottom', ha='left' in matplotlib,
#   which means the BOTTOM-LEFT corner of the text box is at the anchor point,
#   so the text extends upward and to the right.
eps_eri_collision = CollisionHandler(
    plot_on_fail=True,
    anchor_fallbacks=[AnchorPointEnum.TOP_RIGHT],
)

for display_name, (ra, dec) in star_coords.items():
    style = {**label_style}
    if display_name == 'Epsilon Eridani':
        style['offset_x'] = 5
        style['offset_y'] = 5
        ch = eps_eri_collision
    else:
        ch = key_star_collision
    p.text(display_name, ra=ra, dec=dec, style=style, collision_handler=ch)


# ---------------------------------------------------------------------------
# Step 5 – Directed Astrophage transmission arcs.
#
# Drawn last so arrowheads appear on top of everything else.
#
# Color: orange — chosen to contrast clearly with the green constellation
# lines and blue background produced by the BLUE_NIGHT + MAP style.
#
# scale=0.95: pulls each endpoint 5 % inward so the arrowhead clears the
# star dot.  0.97 triggered a Shapely "segment overlaps with splitter"
# error for the WISE→Ross 128 arc at high resolution; 0.95 is safe.
# ---------------------------------------------------------------------------
arc_style = {
    'color': 'darkorange',
    'body_width': 20,
    'head_width': 55,
    'head_height': 90,
    'alpha': 0.9,
}
all_transmissions = list(SKY_CHART_TRANSMISSIONS)
if INCLUDE_OUTER_WISE_TARGETS:
    all_transmissions += [
        (WISE_NAME,  'Wolf 359'),
        (WISE_NAME,  'Lalande 21185'),
        (WISE_NAME,  'Ross 128'),
    ]

for src_name, dst_name in all_transmissions:
    src_ra, src_dec = star_coords[src_name]
    dst_ra, dst_dec = star_coords[dst_name]
    p.arrow(
        origin=(src_ra, src_dec),
        target=(dst_ra, dst_dec),
        style=arc_style,
        scale=0.95,
    )

p.export(OUTPUT_FILE, padding=0.2)
print(f'Done — {OUTPUT_FILE} written.')
